---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { supabase, unwrap } from '../lib/supabase.js';
import { nombreOrganismo } from '../lib/incisos.js';

// Buscador de compras: el formulario se hornea en el build (organismos y
// tipos de procedimiento cambian poco) y los resultados se consultan desde
// el navegador contra PostgREST, igual que el detalle de compra y la ficha
// de proveedor. La publishable key es pública por diseño: solo lectura RLS.
const supabaseUrl = import.meta.env.SUPABASE_URL as string;
const supabaseKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY as string;

const organismos = unwrap<{ id: string; name: string }[]>(
  await supabase.from('entities').select('id,name').eq('is_buyer', true).limit(1000),
  'entities (buyers)',
)
  .map((o) => ({ id: o.id, name: nombreOrganismo(o.name.trim(), o.id) }))
  .sort((a, b) => a.name.localeCompare(b.name, 'es'));

const tipos = unwrap<{ tipo: string; compras: number }[]>(
  await supabase.from('dash_tipos').select('tipo,compras'),
  'dash_tipos',
);
---

<Layout title="Compras">
  <div class="col-span-12">
    <h1 class="text-xl font-semibold tracking-tight">Compras</h1>
    <p class="mt-1 text-sm text-ink-soft">
      buscá por texto, organismo, proveedor, fechas y montos — sin filtros se listan las más grandes
    </p>
  </div>

  <Card title="Filtros" sub="la búsqueda de texto recorre el título y todos los ítems adjudicados; no distingue tildes">
    <form id="filtros" class="grid grid-cols-12 gap-3" autocomplete="off">
      <input
        type="search"
        name="q"
        placeholder="ej.: medicamentos, camión, «servicio de vigilancia», o un nº de compra"
        class="col-span-12 rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink placeholder:text-ink-faint focus:border-primary focus:outline-none md:col-span-9"
      />
      <button
        type="submit"
        class="col-span-12 rounded-md bg-primary px-4 py-1.5 text-sm font-medium text-white hover:bg-primary-deep md:col-span-3"
      >
        Buscar
      </button>

      <label class="col-span-12 flex flex-col gap-1 sm:col-span-6 lg:col-span-4">
        <span class="text-xs text-ink-soft">Organismo</span>
        <select name="org" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none">
          <option value="">Todos</option>
          {organismos.map((o) => <option value={o.id}>{o.name}</option>)}
        </select>
      </label>

      <label class="col-span-12 flex flex-col gap-1 sm:col-span-6 lg:col-span-4">
        <span class="text-xs text-ink-soft">Proveedor</span>
        <input
          type="text"
          name="prov"
          list="prov-opciones"
          placeholder="escribí al menos 3 letras"
          class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink placeholder:text-ink-faint focus:border-primary focus:outline-none"
        />
        <datalist id="prov-opciones"></datalist>
      </label>

      <label class="col-span-6 flex flex-col gap-1 sm:col-span-6 lg:col-span-2">
        <span class="text-xs text-ink-soft">Tipo de procedimiento</span>
        <select name="tipo" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none">
          <option value="">Todos</option>
          {tipos.map((t) => <option value={t.tipo}>{t.tipo}</option>)}
        </select>
      </label>

      <label class="col-span-6 flex flex-col gap-1 sm:col-span-6 lg:col-span-2">
        <span class="text-xs text-ink-soft">Estado</span>
        <select name="estado" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none">
          <option value="">Todos</option>
          <option value="adjudicada">Adjudicada</option>
          <option value="llamado">En llamado</option>
          <option value="cancelada">Cancelada / sin efecto</option>
        </select>
      </label>

      <label class="col-span-6 flex flex-col gap-1 sm:col-span-3 lg:col-span-2">
        <span class="text-xs text-ink-soft">Adjudicada desde</span>
        <input type="date" name="desde" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none" />
      </label>
      <label class="col-span-6 flex flex-col gap-1 sm:col-span-3 lg:col-span-2">
        <span class="text-xs text-ink-soft">hasta</span>
        <input type="date" name="hasta" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none" />
      </label>

      <label class="col-span-6 flex flex-col gap-1 sm:col-span-3 lg:col-span-2">
        <span class="text-xs text-ink-soft">Monto mínimo ($)</span>
        <input type="number" name="min" min="0" placeholder="0" class="num rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink placeholder:text-ink-faint focus:border-primary focus:outline-none" />
      </label>
      <label class="col-span-6 flex flex-col gap-1 sm:col-span-3 lg:col-span-2">
        <span class="text-xs text-ink-soft">máximo ($)</span>
        <input type="number" name="max" min="0" class="num rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none" />
      </label>

      <label class="col-span-6 flex flex-col gap-1 sm:col-span-3 lg:col-span-2">
        <span class="text-xs text-ink-soft">Ordenar por</span>
        <select name="orden" class="rounded-md border border-line bg-surface px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none">
          <option value="monto">Monto</option>
          <option value="fecha">Fecha de adjudicación</option>
        </select>
      </label>

      <div class="col-span-6 flex items-end sm:col-span-3 lg:col-span-2">
        <button type="button" id="limpiar" class="text-sm font-medium text-primary hover:underline">
          Limpiar filtros
        </button>
      </div>

      <p class="col-span-12 text-xs text-ink-faint">
        El tipo de procedimiento solo viene informado por ARCE en ~1 de cada 3 compras; las compras
        sin adjudicación no tienen fecha ni monto y quedan fuera de esos filtros.
      </p>
    </form>
  </Card>

  <Card title="Resultados" sub="proceso completo por ocid; total normalizado a pesos">
    <div
      id="resultados"
      data-supabase-url={supabaseUrl}
      data-supabase-key={supabaseKey}
    >
      <p class="text-sm text-ink-soft">Cargando…</p>
      <noscript><p class="text-sm text-ink-soft">El buscador necesita JavaScript.</p></noscript>
    </div>
  </Card>
</Layout>

<script>
  import { int, uyu, fecha, titulo } from '../lib/format.js';
  import { estadoCompra } from '../lib/estados.js';
  import { guardarBusquedaCompras } from '../lib/busqueda.js';
  import { nombreOrganismo } from '../lib/incisos.js';

  interface Row {
    ocid: string;
    id_compra: number | null;
    tender_title: string | null;
    status: string | null;
    organismo: string | null;
    buyer_id: string | null;
    adjudicaciones: number;
    total_uyu: number | null;
    item_principal: string | null;
    fecha: string | null;
    tipo: string | null;
  }

  const POR_PAGINA = 50;

  // Grupos semánticos sobre los status crudos (mezcla de estados OCDS y tags
  // de release, ver estados.ts). Filtrar por grupo evita exponer esa sopa.
  const ESTADOS_FILTRO: Record<string, string[]> = {
    adjudicada: ['award', 'awardUpdate', 'complete'],
    llamado: ['active', 'tender', 'tenderUpdate', 'tenderAmendment', 'planned'],
    cancelada: ['cancelled', 'tenderCancellation', 'unsuccessful'],
  };

  const cont = document.getElementById('resultados')!;
  const form = document.getElementById('filtros') as HTMLFormElement;
  const provInput = form.elements.namedItem('prov') as HTMLInputElement;
  const provLista = document.getElementById('prov-opciones') as HTMLDataListElement;
  const { supabaseUrl, supabaseKey } = cont.dataset;

  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => `&#${c.charCodeAt(0)};`);

  async function pg(recurso: string, params: URLSearchParams, prefer?: string, signal?: AbortSignal) {
    const headers: Record<string, string> = { apikey: supabaseKey! };
    if (prefer) headers.Prefer = prefer;
    const res = await fetch(`${supabaseUrl}/rest/v1/${recurso}?${params}`, { headers, signal });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res;
  }

  // ── Autocompletado de proveedor ────────────────────────────────────────
  // name → id de las opciones ya vistas; al buscar se resuelve contra esto
  // y, si no está, con una consulta puntual a entities.
  const provIds = new Map<string, string>();
  let provTimer: number | undefined;

  // ilike de PostgREST: * es comodín; %, _ y \ del usuario se van (ningún
  // proveedor real los tiene) y las comillas romperían el or=() quoteado.
  const patronIlike = (v: string) => v.replace(/[%_\\"]/g, '');

  async function sugerirProveedores() {
    const v = provInput.value.trim();
    if (v.length < 3) return;
    const params = new URLSearchParams({
      select: 'id,name',
      is_supplier: 'eq.true',
      or: `(name.ilike."*${patronIlike(v)}*",legal_name.ilike."*${patronIlike(v)}*")`,
      order: 'name',
      limit: '20',
    });
    try {
      const rows = (await (await pg('entities', params)).json()) as { id: string; name: string }[];
      provLista.innerHTML = rows
        .map((r) => {
          provIds.set(r.name, r.id);
          return `<option value="${esc(r.name)}"></option>`;
        })
        .join('');
    } catch {
      /* sugerencias: mejor mudas que ruidosas */
    }
  }

  provInput.addEventListener('input', () => {
    clearTimeout(provTimer);
    provTimer = window.setTimeout(sugerirProveedores, 250);
  });

  /** Devuelve el id del proveedor tipeado, o un mensaje de error si es ambiguo. */
  async function resolverProveedor(v: string): Promise<{ id?: string; error?: string }> {
    const conocido = provIds.get(v);
    if (conocido) return { id: conocido };
    const params = new URLSearchParams({
      select: 'id,name',
      is_supplier: 'eq.true',
      or: `(name.ilike."*${patronIlike(v)}*",legal_name.ilike."*${patronIlike(v)}*")`,
      limit: '5',
    });
    const rows = (await (await pg('entities', params)).json()) as { id: string; name: string }[];
    const exacto = rows.find((r) => r.name.toLowerCase() === v.toLowerCase());
    if (exacto) return { id: exacto.id };
    if (rows.length === 1) return { id: rows[0].id };
    if (rows.length === 0) return { error: `No encontramos ningún proveedor que coincida con «${v}».` };
    return { error: `Hay varios proveedores que coinciden con «${v}»: elegí uno de la lista.` };
  }

  // ── Estado de la búsqueda ──────────────────────────────────────────────
  interface Filtros {
    q: string;
    org: string;
    prov: string; // nombre tipeado; se resuelve a id al buscar
    provId: string;
    tipo: string;
    estado: string;
    desde: string;
    hasta: string;
    min: string;
    max: string;
    orden: string;
    pagina: number;
  }

  const val = (n: string) => (form.elements.namedItem(n) as HTMLInputElement | HTMLSelectElement).value.trim();
  const setVal = (n: string, v: string) => {
    (form.elements.namedItem(n) as HTMLInputElement | HTMLSelectElement).value = v;
  };

  function leerFormulario(pagina: number): Filtros {
    return {
      q: val('q'),
      org: val('org'),
      prov: val('prov'),
      provId: '',
      tipo: val('tipo'),
      estado: val('estado'),
      desde: val('desde'),
      hasta: val('hasta'),
      min: val('min'),
      max: val('max'),
      orden: val('orden'),
      pagina,
    };
  }

  /** La URL es el estado: cada búsqueda queda compartible. */
  function escribirUrl(f: Filtros) {
    const p = new URLSearchParams();
    if (f.q) p.set('q', f.q);
    if (f.org) p.set('org', f.org);
    if (f.provId) p.set('prov', f.provId);
    if (f.prov) p.set('provn', f.prov);
    if (f.tipo) p.set('tipo', f.tipo);
    if (f.estado) p.set('estado', f.estado);
    if (f.desde) p.set('desde', f.desde);
    if (f.hasta) p.set('hasta', f.hasta);
    if (f.min) p.set('min', f.min);
    if (f.max) p.set('max', f.max);
    if (f.orden !== 'monto') p.set('orden', f.orden);
    if (f.pagina > 1) p.set('p', String(f.pagina));
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    guardarBusquedaCompras(qs);
  }

  function paramsPostgrest(f: Filtros): URLSearchParams {
    const p = new URLSearchParams();
    p.set(
      'select',
      'ocid,id_compra,tender_title,status,organismo,buyer_id,adjudicaciones,total_uyu,item_principal,fecha,tipo',
    );
    // Un número (o un ocid pegado) busca la compra puntual, no texto.
    const id = f.q.match(/^(?:ocds-yfs5dr-)?(\d{5,})$/);
    if (id) p.set('id_compra', `eq.${id[1]}`);
    else if (f.q) p.set('busqueda', `wfts(es_unaccent).${f.q}`);
    if (f.org) p.set('buyer_id', `eq.${f.org}`);
    if (f.provId) p.set('supplier_ids', `cs.{"${f.provId.replace(/(["\\])/g, '\\$1')}"}`);
    if (f.tipo) p.set('tipo', `eq.${f.tipo}`);
    if (f.estado && ESTADOS_FILTRO[f.estado]) p.set('status', `in.(${ESTADOS_FILTRO[f.estado].join(',')})`);
    if (f.desde) p.append('fecha', `gte.${f.desde}`);
    if (f.hasta) p.append('fecha', `lte.${f.hasta}`);
    if (f.min && !isNaN(+f.min)) p.append('total_uyu', `gte.${+f.min}`);
    if (f.max && !isNaN(+f.max)) p.append('total_uyu', `lte.${+f.max}`);
    p.set(
      'order',
      f.orden === 'fecha' ? 'fecha.desc.nullslast,ocid.asc' : 'total_uyu.desc.nullslast,ocid.asc',
    );
    p.set('limit', String(POR_PAGINA));
    p.set('offset', String((f.pagina - 1) * POR_PAGINA));
    return p;
  }

  // ── Render ─────────────────────────────────────────────────────────────
  const mensaje = (t: string) => {
    cont.innerHTML = `<p class="text-sm text-ink-soft">${esc(t)}</p>`;
  };

  const filaCompra = (c: Row) => {
    const objeto = c.tender_title ?? c.item_principal;
    const organismo = nombreOrganismo(c.organismo, c.buyer_id);
    const link = (inner: string, extra = '') =>
      c.id_compra != null ? `<a href="/compras/${c.id_compra}" class="${extra} hover:underline">${inner}</a>` : inner;
    return `
      <tr class="border-b border-line last:border-b-0">
        <td class="num py-2.5 pr-4 whitespace-nowrap">${link(String(c.id_compra ?? '—'), 'font-medium text-primary')}</td>
        <td class="max-w-[24rem] truncate py-2.5 pr-4" title="${esc(objeto ?? '')}">${link(esc(titulo(objeto, 70)))}</td>
        <td class="max-w-[14rem] truncate py-2.5 pr-4 text-ink-soft" title="${esc(organismo ?? '')}">${esc(organismo ?? '—')}</td>
        <td class="py-2.5 pr-4 whitespace-nowrap text-ink-soft">${esc(estadoCompra(c.status))}</td>
        <td class="num py-2.5 pr-4 text-right text-ink-soft">${int(c.adjudicaciones)}</td>
        <td class="num py-2.5 pr-4 text-right whitespace-nowrap">${uyu(c.total_uyu)}</td>
        <td class="num py-2.5 whitespace-nowrap text-ink-soft">${fecha(c.fecha)}</td>
      </tr>`;
  };

  function render(rows: Row[], total: number, f: Filtros) {
    if (!rows.length) {
      mensaje('No encontramos compras con esos filtros.');
      return;
    }
    const paginas = Math.max(1, Math.ceil(total / POR_PAGINA));
    const boton = (label: string, pagina: number, activo: boolean) =>
      `<button type="button" data-pagina="${pagina}" ${activo ? '' : 'disabled'}
        class="rounded-md border border-line px-3 py-1 text-sm ${activo ? 'text-primary hover:bg-primary-tint' : 'text-ink-faint'}">${label}</button>`;

    cont.innerHTML = `
      <p class="mb-3 text-sm text-ink-soft"><span class="num font-medium text-ink">${int(total)}</span> compras encontradas</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-line text-left text-xs text-ink-faint">
              <th class="py-2 pr-4 font-medium">Compra</th>
              <th class="py-2 pr-4 font-medium">Objeto</th>
              <th class="py-2 pr-4 font-medium">Organismo</th>
              <th class="py-2 pr-4 font-medium">Estado</th>
              <th class="py-2 pr-4 text-right font-medium">Adj.</th>
              <th class="py-2 pr-4 text-right font-medium">Total</th>
              <th class="py-2 font-medium">Adjudicada</th>
            </tr>
          </thead>
          <tbody>${rows.map(filaCompra).join('')}</tbody>
        </table>
      </div>
      <div class="mt-4 flex items-center justify-between gap-3">
        ${boton('← Anterior', f.pagina - 1, f.pagina > 1)}
        <span class="text-xs text-ink-faint">página ${int(f.pagina)} de ${int(paginas)}</span>
        ${boton('Siguiente →', f.pagina + 1, f.pagina < paginas)}
      </div>`;
  }

  // ── Búsqueda ───────────────────────────────────────────────────────────
  let abortar: AbortController | undefined;

  async function buscar(f: Filtros) {
    abortar?.abort();
    abortar = new AbortController();
    const { signal } = abortar;
    mensaje('Buscando…');

    try {
      if (f.prov && !f.provId) {
        const r = await resolverProveedor(f.prov);
        if (r.error) {
          escribirUrl(f);
          mensaje(r.error);
          return;
        }
        f.provId = r.id!;
      }
      escribirUrl(f);

      const res = await pg('dash_compras', paramsPostgrest(f), 'count=exact', signal);
      const rows = (await res.json()) as Row[];
      // Content-Range: "0-49/1234" → total tras la barra.
      const total = Number(res.headers.get('content-range')?.split('/')[1] ?? rows.length);
      render(rows, total, f);
      cont.scrollIntoView({ block: 'nearest' });
    } catch (e) {
      if (signal.aborted) return;
      mensaje(`No pudimos buscar (${e instanceof Error ? e.message : e}). Probá de nuevo.`);
    }
  }

  // Ningún filtro busca solo: todos esperan el botón Buscar (o Enter). Buscar
  // al cambiar un campo saltaba a los resultados a mitad de carga del
  // formulario (p. ej. entre el «desde» y el «hasta» de un rango de fechas).
  form.addEventListener('submit', (ev) => {
    ev.preventDefault();
    buscar(leerFormulario(1));
  });

  document.getElementById('limpiar')!.addEventListener('click', () => {
    form.reset();
    provLista.innerHTML = '';
    buscar(leerFormulario(1));
  });

  cont.addEventListener('click', (ev) => {
    const btn = (ev.target as HTMLElement).closest('button[data-pagina]');
    if (!btn) return;
    const f = leerFormulario(Number(btn.getAttribute('data-pagina')));
    buscar(f);
  });

  // ── Arranque: la URL manda ─────────────────────────────────────────────
  async function iniciar() {
    const u = new URLSearchParams(location.search);
    setVal('q', u.get('q') ?? '');
    setVal('org', u.get('org') ?? '');
    setVal('tipo', u.get('tipo') ?? '');
    setVal('estado', u.get('estado') ?? '');
    setVal('desde', u.get('desde') ?? '');
    setVal('hasta', u.get('hasta') ?? '');
    setVal('min', u.get('min') ?? '');
    setVal('max', u.get('max') ?? '');
    setVal('orden', u.get('orden') ?? 'monto');

    const f = leerFormulario(Math.max(1, Number(u.get('p') ?? 1) || 1));
    const provId = u.get('prov');
    if (provId) {
      f.provId = provId;
      let nombre = u.get('provn') ?? '';
      if (!nombre) {
        try {
          const params = new URLSearchParams({ select: 'name', id: `eq.${provId}`, limit: '1' });
          const rows = (await (await pg('entities', params)).json()) as { name: string }[];
          nombre = rows[0]?.name ?? provId;
        } catch {
          nombre = provId;
        }
      }
      setVal('prov', nombre);
      provIds.set(nombre, provId);
      f.prov = nombre;
    }
    buscar(f);
  }

  iniciar();
</script>
