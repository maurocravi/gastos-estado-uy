---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Kpi from '../../components/Kpi.astro';
import { int, uyu, uyuM, pct, fecha, titulo } from '../../lib/format.js';
import { cargarEntidades, rankingContrapartes, slugEntidad } from '../../lib/entidades.js';

interface Cliente {
  id: string;
  name: string;
  adjudicaciones: number;
  total_uyu: number;
}
interface CompraGanada {
  id_compra: number | null;
  objeto: string | null;
  organismo: string | null;
  organismo_id: string | null;
  fecha: string | null;
  adjudicaciones: number;
  total_uyu: number;
}
interface Props {
  nombre: string;
  entidadId: string;
  totalUyu: number;
  nAdjudicaciones: number;
  clientes: Cliente[];
  compras: CompraGanada[];
}

const TOP_CLIENTES = 15;
const TOP_COMPRAS = 50;

export async function getStaticPaths() {
  const datos = await cargarEntidades();
  return datos.entidades
    .filter((e) => e.is_supplier)
    .map((e) => {
      const adjudicaciones = datos.adjudicacionesPorProveedor.get(e.id) ?? [];
      const clientes = rankingContrapartes(adjudicaciones, (a) => a.buyer_id).map((c) => ({
        ...c,
        name: datos.nombrePorId.get(c.id) ?? c.id,
      }));

      // Una fila por compra: un proveedor puede tener varias adjudicaciones
      // en el mismo proceso (ajustes, lotes) y su total no es el de la compra.
      const porCompra = new Map<string, CompraGanada>();
      for (const a of adjudicaciones) {
        const compra = datos.compraPorOcid.get(a.ocid);
        const fila = porCompra.get(a.ocid) ?? {
          id_compra: a.id_compra,
          objeto: compra ? (compra.tender_title ?? compra.item_principal) : null,
          organismo: compra?.organismo ?? null,
          organismo_id: compra?.buyer_id ?? null,
          fecha: null,
          adjudicaciones: 0,
          total_uyu: 0,
        };
        fila.adjudicaciones += 1;
        fila.total_uyu += a.total_uyu ?? 0;
        if (a.award_date && (!fila.fecha || a.award_date > fila.fecha)) fila.fecha = a.award_date;
        porCompra.set(a.ocid, fila);
      }
      const compras = [...porCompra.values()].sort((x, y) => y.total_uyu - x.total_uyu);

      return {
        params: { id: slugEntidad(e.id) },
        props: {
          nombre: e.name,
          entidadId: e.id,
          totalUyu: adjudicaciones.reduce((s, a) => s + (a.total_uyu ?? 0), 0),
          nAdjudicaciones: adjudicaciones.length,
          clientes,
          compras,
        } satisfies Props,
      };
    });
}

const { nombre, entidadId, totalUyu, nAdjudicaciones, clientes, compras } = Astro.props as Props;

const topClientes = clientes.slice(0, TOP_CLIENTES);
const topCompras = compras.slice(0, TOP_COMPRAS);
---

<Layout title={nombre}>
  <div class="col-span-12">
    <a href="/proveedores" class="text-sm font-medium text-primary hover:underline">← Proveedores</a>
    <h1 class="mt-2 text-xl font-semibold tracking-tight">{nombre}</h1>
    <p class="mt-1 text-sm text-ink-soft">proveedor del Estado · id {entidadId}</p>
  </div>

  <Kpi
    label="Adjudicado"
    value={uyuM(totalUyu)}
    sub="pesos uruguayos, montos normalizados"
    class="col-span-12 sm:col-span-4"
  />
  <Kpi
    label="Adjudicaciones"
    value={int(nAdjudicaciones)}
    sub={`en ${int(compras.length)} compras`}
    class="col-span-12 sm:col-span-4"
  />
  <Kpi
    label="Organismos clientes"
    value={int(clientes.length)}
    sub={clientes.length
      ? `el principal concentra ${pct(totalUyu ? clientes[0].total_uyu / totalUyu : null)}`
      : 'sin adjudicaciones registradas'}
    class="col-span-12 sm:col-span-4"
  />

  <Card
    title="Principales clientes"
    sub={`top ${topClientes.length} de ${int(clientes.length)} organismos por monto adjudicado`}
  >
    {
      topClientes.length === 0 ? (
        <p class="text-sm text-ink-soft">
          Este proveedor todavía no tiene adjudicaciones registradas en el feed OCDS.
        </p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-line text-left text-xs text-ink-faint">
                <th class="py-2 pr-4 font-medium">#</th>
                <th class="py-2 pr-4 font-medium">Organismo</th>
                <th class="py-2 pr-4 text-right font-medium">Adjudicaciones</th>
                <th class="py-2 pr-4 text-right font-medium">Total</th>
                <th class="py-2 text-right font-medium">% del proveedor</th>
              </tr>
            </thead>
            <tbody>
              {topClientes.map((c, i) => (
                <tr class="border-b border-line last:border-b-0">
                  <td class="num py-2.5 pr-4 text-xs text-ink-faint">{i + 1}</td>
                  <td class="max-w-[30rem] truncate py-2.5 pr-4" title={c.name}>
                    <a href={`/organismos/${slugEntidad(c.id)}`} class="hover:underline">
                      {c.name}
                    </a>
                  </td>
                  <td class="num py-2.5 pr-4 text-right text-ink-soft">{int(c.adjudicaciones)}</td>
                  <td class="num py-2.5 pr-4 text-right whitespace-nowrap">{uyu(c.total_uyu)}</td>
                  <td class="num py-2.5 text-right text-ink-soft">
                    {pct(totalUyu ? c.total_uyu / totalUyu : null)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </Card>

  <Card
    title="Compras en las que fue adjudicado"
    sub={`top ${topCompras.length} de ${int(compras.length)}; el total es lo adjudicado a este proveedor, no toda la compra`}
  >
    {
      topCompras.length === 0 ? (
        <p class="text-sm text-ink-soft">Sin adjudicaciones registradas.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-line text-left text-xs text-ink-faint">
                <th class="py-2 pr-4 font-medium">Compra</th>
                <th class="py-2 pr-4 font-medium">Objeto</th>
                <th class="py-2 pr-4 font-medium">Organismo</th>
                <th class="py-2 pr-4 font-medium">Fecha</th>
                <th class="py-2 text-right font-medium">Adjudicado</th>
              </tr>
            </thead>
            <tbody>
              {topCompras.map((c) => (
                <tr class="border-b border-line last:border-b-0">
                  <td class="num py-2.5 pr-4 whitespace-nowrap">
                    {c.id_compra != null ? (
                      <a
                        href={`/compras/${c.id_compra}`}
                        class="font-medium text-primary hover:underline"
                      >
                        {c.id_compra}
                      </a>
                    ) : (
                      '—'
                    )}
                  </td>
                  <td class="max-w-[24rem] truncate py-2.5 pr-4" title={c.objeto ?? undefined}>
                    {titulo(c.objeto, 70)}
                  </td>
                  <td
                    class="max-w-[14rem] truncate py-2.5 pr-4 text-ink-soft"
                    title={c.organismo ?? undefined}
                  >
                    {c.organismo_id ? (
                      <a href={`/organismos/${slugEntidad(c.organismo_id)}`} class="hover:underline">
                        {c.organismo ?? c.organismo_id}
                      </a>
                    ) : (
                      (c.organismo ?? '—')
                    )}
                  </td>
                  <td class="num py-2.5 pr-4 whitespace-nowrap text-ink-soft">{fecha(c.fecha)}</td>
                  <td class="num py-2.5 text-right whitespace-nowrap">{uyu(c.total_uyu)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </Card>
</Layout>
