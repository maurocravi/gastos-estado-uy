---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Kpi from '../../components/Kpi.astro';
import { supabase, unwrap } from '../../lib/supabase.js';
import { int, uyu, cant, moneda, fecha, titulo } from '../../lib/format.js';
import { estadoCompra, estadoAdjudicacion } from '../../lib/estados.js';
import { slugEntidad } from '../../lib/entidades.js';

interface Item {
  description: string | null;
  classification_id: string | null;
  classification_desc: string | null;
  quantity: number | null;
  unit_name: string | null;
  amount: number | null;
  currency: string | null;
  amount_uyu: number | null;
}
interface Adjudicacion {
  award_id: string;
  status: string | null;
  award_date: string | null;
  notice_url: string | null;
  supplier: { id: string; name: string } | null;
  items: Item[];
}
interface Compra {
  ocid: string;
  id_compra: number;
  tender_title: string | null;
  status: string | null;
  first_seen: string;
  last_updated: string;
  buyer: { id: string; name: string } | null;
  awards: Adjudicacion[];
}

export async function getStaticPaths() {
  // Una sola pasada paginada con embeds (PostgREST corta en 1000 filas top-level;
  // los embeds no pagan ese tope y ninguna compra supera ~400 items).
  const PAGINA = 1000;
  const compras: Compra[] = [];
  for (let desde = 0; ; desde += PAGINA) {
    const pagina = unwrap<Compra[]>(
      await supabase
        .from('purchases')
        .select(
          `ocid, id_compra, tender_title, status, first_seen, last_updated,
           buyer:entities!purchases_buyer_id_fkey(id, name),
           awards(award_id, status, award_date, notice_url,
             supplier:entities!awards_supplier_id_fkey(id, name),
             items:award_items(description, classification_id, classification_desc,
               quantity, unit_name, amount, currency, amount_uyu))`,
        )
        .order('ocid')
        .range(desde, desde + PAGINA - 1)
        // Los embeds many-to-one vienen como objeto, pero sin tipos generados
        // supabase-js los infiere como array: se fija el tipo real acá.
        .overrideTypes<Compra[], { merge: false }>(),
      'purchases (detalle)',
    );
    compras.push(...pagina);
    if (pagina.length < PAGINA) break;
  }
  return compras.map((compra) => ({
    params: { id: String(compra.id_compra) },
    props: { compra },
  }));
}

interface Props {
  compra: Compra;
}
const { compra } = Astro.props;

const adjudicaciones = [...compra.awards].sort((a, b) =>
  (a.award_date ?? '9999').localeCompare(b.award_date ?? '9999'),
);

const totalItem = (i: Item) =>
  i.amount_uyu == null ? null : i.amount_uyu * (i.quantity ?? 1);
const totalAdj = (a: Adjudicacion) =>
  a.items.reduce((s, i) => s + (totalItem(i) ?? 0), 0);
const totalCompra = adjudicaciones.reduce((s, a) => s + totalAdj(a), 0);
const nItems = adjudicaciones.reduce((s, a) => s + a.items.length, 0);

// Objeto de la compra: el feed solo trae tender.title en los llamados;
// si falta, usamos el ítem adjudicado de mayor monto como proxy.
const itemPrincipal = adjudicaciones
  .flatMap((a) => a.items)
  .sort((x, y) => (totalItem(y) ?? -1) - (totalItem(x) ?? -1))
  .map((i) => i.description ?? i.classification_desc)
  .find((d) => d != null);
const objeto = compra.tender_title ?? itemPrincipal ?? null;

const urlArce = `https://www.comprasestatales.gub.uy/consultas/detalle/mostrar-llamado/1/id/${compra.id_compra}`;
---

<Layout title={`Compra ${compra.id_compra}`}>
  <div class="col-span-12">
    <a href="/compras" class="text-sm font-medium text-primary hover:underline">← Compras</a>
    <h1 class="mt-2 text-xl font-semibold tracking-tight">{titulo(objeto, 140)}</h1>
    <p class="mt-1 text-sm text-ink-soft">
      compra {compra.id_compra} ·{' '}
      {
        compra.buyer ? (
          <a href={`/organismos/${slugEntidad(compra.buyer.id)}`} class="hover:underline">
            {compra.buyer.name}
          </a>
        ) : (
          'organismo sin identificar'
        )
      }
    </p>
  </div>

  <Kpi
    label="Adjudicado"
    value={uyu(adjudicaciones.length ? totalCompra : null)}
    sub="pesos uruguayos, montos normalizados"
    class="col-span-12 sm:col-span-4"
  />
  <Kpi
    label="Adjudicaciones"
    value={int(adjudicaciones.length)}
    sub={`${int(nItems)} ítems`}
    class="col-span-12 sm:col-span-4"
  />
  <Kpi
    label="Estado"
    value={estadoCompra(compra.status)}
    sub={`actualizada el ${fecha(compra.last_updated)}`}
    class="col-span-12 sm:col-span-4"
  />

  <Card title="Ficha" sub="identificadores y fuente del proceso">
    <dl class="grid grid-cols-1 gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
      <div class="flex justify-between gap-4 border-b border-line pb-2">
        <dt class="text-ink-faint">Organismo</dt>
        <dd class="text-right">
          {
            compra.buyer ? (
              <a
                href={`/organismos/${slugEntidad(compra.buyer.id)}`}
                class="font-medium text-primary hover:underline"
              >
                {compra.buyer.name}
              </a>
            ) : (
              '—'
            )
          }
        </dd>
      </div>
      <div class="flex justify-between gap-4 border-b border-line pb-2">
        <dt class="text-ink-faint">ocid</dt>
        <dd class="num text-right text-ink-soft">{compra.ocid}</dd>
      </div>
      <div class="flex justify-between gap-4 border-b border-line pb-2">
        <dt class="text-ink-faint">Primera vez vista</dt>
        <dd class="num text-right">{fecha(compra.first_seen)}</dd>
      </div>
      <div class="flex justify-between gap-4 border-b border-line pb-2">
        <dt class="text-ink-faint">Última actualización</dt>
        <dd class="num text-right">{fecha(compra.last_updated)}</dd>
      </div>
    </dl>
    <p class="mt-4 text-sm">
      <a href={urlArce} rel="noopener" target="_blank" class="font-medium text-primary hover:underline">
        Ver en comprasestatales.gub.uy →
      </a>
    </p>
  </Card>

  {
    adjudicaciones.length === 0 && (
      <Card title="Adjudicaciones">
        <p class="text-sm text-ink-soft">
          Esta compra todavía no tiene adjudicaciones registradas en el feed OCDS.
        </p>
      </Card>
    )
  }

  {
    adjudicaciones.map((a) => (
      <Card
        title={`Adjudicación · ${a.supplier?.name ?? 'proveedor sin identificar'}`}
        sub={`${fecha(a.award_date)} · ${estadoAdjudicacion(a.status)} · ${int(a.items.length)} ítems`}
      >
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-line text-left text-xs text-ink-faint">
                <th class="py-2 pr-4 font-medium">Ítem</th>
                <th class="py-2 pr-4 font-medium">Clasificación</th>
                <th class="py-2 pr-4 text-right font-medium">Cant.</th>
                <th class="py-2 pr-4 font-medium">Unidad</th>
                <th class="py-2 pr-4 text-right font-medium">Precio unit.</th>
                <th class="py-2 text-right font-medium">Total</th>
              </tr>
            </thead>
            <tbody>
              {a.items.map((i) => (
                <tr class="border-b border-line last:border-b-0">
                  <td class="max-w-[24rem] truncate py-2.5 pr-4" title={i.description ?? undefined}>
                    {titulo(i.description, 70)}
                  </td>
                  <td
                    class="max-w-[16rem] truncate py-2.5 pr-4 text-ink-soft"
                    title={i.classification_desc ?? undefined}
                  >
                    {i.classification_desc ?? i.classification_id ?? '—'}
                  </td>
                  <td class="num py-2.5 pr-4 text-right text-ink-soft">{cant(i.quantity)}</td>
                  <td class="py-2.5 pr-4 text-ink-soft">{i.unit_name ?? '—'}</td>
                  <td class="num py-2.5 pr-4 text-right whitespace-nowrap text-ink-soft">
                    {moneda(i.amount, i.currency)}
                  </td>
                  <td class="num py-2.5 text-right whitespace-nowrap">{uyu(totalItem(i))}</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="border-t border-line text-xs">
                <td colspan="5" class="py-2.5 pr-4 text-right font-medium text-ink-faint">
                  Total adjudicación
                </td>
                <td class="num py-2.5 text-right font-medium whitespace-nowrap">
                  {uyu(totalAdj(a))}
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
        {(a.supplier || a.notice_url) && (
          <p class="mt-4 flex flex-wrap justify-end gap-x-6 text-sm">
            {a.supplier && (
              <a
                href={`/proveedores/${slugEntidad(a.supplier.id)}`}
                class="font-medium text-primary hover:underline"
              >
                Ficha del proveedor →
              </a>
            )}
            {a.notice_url && (
              <a
                href={a.notice_url}
                rel="noopener"
                target="_blank"
                class="font-medium text-primary hover:underline"
              >
                Acta de adjudicación (PDF) →
              </a>
            )}
          </p>
        )}
      </Card>
    ))
  }
</Layout>
