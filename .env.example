# Copiá este archivo a .env y completá los valores.
#   cp .env.example .env

# URL del proyecto Supabase (Project Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role key (Project Settings → API → Project API keys → service_role).
# Es SECRETA: la ingesta la usa para saltear RLS al escribir.
# Nunca la pongas en el frontend ni la commitees al repo.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Key pública (frontend / build): solo lectura vía policies RLS.
# Project Settings → API Keys → Publishable key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
