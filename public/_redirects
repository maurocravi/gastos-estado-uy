# Cloudflare Pages: /compras/{id} y /proveedores/{slug} sirven páginas únicas
# client-side (rewrite 200, la URL no cambia); el id se lee del path en el
# cliente. Los listados /compras y /proveedores no matchean (la regla exige un
# segmento más, no vacío).
/compras/:id /compras/detalle/ 200
/proveedores/:id /proveedores/detalle/ 200
/precios/:id /precios/detalle/ 200
